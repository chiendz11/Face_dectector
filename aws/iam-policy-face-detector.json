{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "SSMReadParameters",
            "Effect": "Allow",
            "Action": [
                "ssm:GetParameter",
                "ssm:GetParameters",
                "ssm:GetParametersByPath",
                "ssm:DescribeParameters"
            ],
            "Resource": "arn:aws:ssm:${AWS_REGION}:${AWS_ACCOUNT_ID}:parameter/facedetector/*"
        },
        {
            "Sid": "S3ReadSnapshots",
            "Effect": "Allow",
            "Action": [
                "s3:GetObject",
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::face-detector-employee-images",
                "arn:aws:s3:::face-detector-employee-images/*"
            ]
        },
        {
            "Sid": "RDSDescribe",
            "Effect": "Allow",
            "Action": [
                "rds:DescribeDBInstances",
                "rds:DescribeDBClusters"
            ],
            "Resource": "*"
        }
    ]
}