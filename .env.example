POSTGRES_DB=face_detector
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/face_detector

REDIS_URL=redis://redis:6379/0

QDRANT_URL=http://vector-db:6333

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=face-snapshots

API_PREFIX=/api
MODEL_NAME=VGG-Face
MODEL_VERSION=2026.04-baseline
MATCH_THRESHOLD=0.35

JWT_SECRET_KEY=replace-with-secure-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ACCESS_TOKEN_EXPIRE_MINUTES=60

BACKEND_BASE_URL=http://localhost
EDGE_DEVICE_NAME=main-gate-01
SCAN_INTERVAL_SECONDS=1.0


# --- VPS CONNECTION SETTINGS ---
# Địa chỉ IP Public của máy EC2 bạn vừa copy (ví dụ: 13.212.x.x)
VPS_HOST=13.239.222.5

# User mặc định của Ubuntu trên AWS luôn là ubuntu
VPS_USER=ubuntu

# Đường dẫn đến file .pem trên máy tính của bạn
# Ví dụ trên Windows: C:/Users/TenBan/Downloads/vps-key.pem
# Ví dụ trên Linux/Mac/GitBash: ~/.ssh/vps-key.pem
SSH_KEY_PATH=D:\Downloads\vps-key.pem

# Thư mục nơi bạn muốn code nằm trên server
TARGET_DIR=/home/ubuntu/face-detector
