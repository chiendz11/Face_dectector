APP_NAME=Face Detector Backend
API_PREFIX=/api

POSTGRES_DB=face_detector
POSTGRES_USER=postgres
POSTGRES_PASSWORD=local-dev-postgres
DATABASE_URL=postgresql+psycopg://postgres:local-dev-postgres@db:5432/face_detector
DATABASE_REPLICA_URLS=

REDIS_URL=redis://redis:6379/0
REDIS_ADDRESS=redis:6379
REDIS_PASSWORD=

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=local-dev-minio
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=local-dev-minio
MINIO_BUCKET=face-snapshots
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_S3_PRESIGNED_URL_EXPIRE_SECONDS=3600

MODEL_NAME=VGG-Face
MODEL_VERSION=2026.04-baseline
EMBEDDING_DIMENSIONS=16
MATCH_THRESHOLD=0.35
DEDUPE_WINDOW_SECONDS=30

DB_RETRY_ATTEMPTS=3
DB_RETRY_BACKOFF_SECONDS=0.5
DB_CIRCUIT_FAILURE_THRESHOLD=5
DB_CIRCUIT_RECOVERY_SECONDS=30

S3_RETRY_ATTEMPTS=3
S3_RETRY_BACKOFF_SECONDS=1.0
S3_CIRCUIT_FAILURE_THRESHOLD=5
S3_CIRCUIT_RECOVERY_SECONDS=30

SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_RECYCLE_SECONDS=1800

JWT_SECRET_KEY=local-dev-jwt-secret
JWT_ALGORITHM=HS256
ADMIN_USERNAME=admin
ADMIN_PASSWORD=local-admin-password
ACCESS_TOKEN_EXPIRE_MINUTES=60
