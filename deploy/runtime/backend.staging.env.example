APP_NAME=Face Detector Backend
API_PREFIX=/api

POSTGRES_DB=face_detector
POSTGRES_USER=face_detector_app
POSTGRES_PASSWORD=change-me-staging-postgres
DATABASE_URL=postgresql+psycopg://face_detector_app:change-me-staging-postgres@staging-postgres.cluster-xxxx.ap-southeast-1.rds.amazonaws.com:5432/face_detector
DATABASE_REPLICA_URLS=

REDIS_URL=rediss://:change-me-staging-redis@staging-redis.xxxxxx.cache.amazonaws.com:6379/0
REDIS_ADDRESS=staging-redis.xxxxxx.cache.amazonaws.com:6379
REDIS_PASSWORD=change-me-staging-redis

MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
MINIO_ENDPOINT=
MINIO_PUBLIC_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=face-snapshots
AWS_S3_BUCKET=face-detector-employee-images-staging
AWS_S3_REGION=ap-southeast-1
AWS_S3_PRESIGNED_URL_EXPIRE_SECONDS=900

MODEL_NAME=VGG-Face
MODEL_VERSION=2026.04-baseline
EMBEDDING_DIMENSIONS=16
MATCH_THRESHOLD=0.35
DEDUPE_WINDOW_SECONDS=30

DB_RETRY_ATTEMPTS=3
DB_RETRY_BACKOFF_SECONDS=0.5
DB_CIRCUIT_FAILURE_THRESHOLD=5
DB_CIRCUIT_RECOVERY_SECONDS=30

S3_RETRY_ATTEMPTS=3
S3_RETRY_BACKOFF_SECONDS=1.0
S3_CIRCUIT_FAILURE_THRESHOLD=5
S3_CIRCUIT_RECOVERY_SECONDS=30

SQLALCHEMY_POOL_SIZE=10
SQLALCHEMY_MAX_OVERFLOW=20
SQLALCHEMY_POOL_RECYCLE_SECONDS=1800

JWT_SECRET_KEY=change-me-staging-jwt
JWT_ALGORITHM=HS256
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-staging-admin
ACCESS_TOKEN_EXPIRE_MINUTES=60